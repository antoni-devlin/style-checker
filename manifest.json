{
  "manifest_version": 3,
  "name": "GOV.UK Style Assistant",
  "version": "0.1",
  "description": "Checks publisher content for style issues and broken links.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://publisher.publishing.service.gov.uk/*","https://signon.integration.publishing.service.gov.uk/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://publisher.publishing.service.gov.uk/*","https://signon.integration.publishing.service.gov.uk/*"],
      "js": ["style-rules.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
