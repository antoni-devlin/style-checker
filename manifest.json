{
  "manifest_version": 3,
  "name": "GOV.UK Style Assistant",
  "version": "0.1",
  "description": "Checks publisher content for style issues and broken links.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["style-rules.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
