{
  "manifest_version": 3,
  "name": "GOV.UK Style Assistant",
  "version": "0.1",
  "description": "Checks content in currently open publisher draft for style issues.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
